#!/usr/bin/env exsh

# This case exercises the dnslookup builtin, which needs libcurl-based
# networking. A minimal pscal-core (curl OFF) omits it, so probe first and
# self-skip (exit 77 = skip) when networking is unavailable. The harness treats
# 77 as a skip, keeping a minimal build green while a curl-enabled build runs
# the test for real. The probe runs in a command substitution so the builtin's
# fatal "unavailable" abort stays in the subshell instead of killing this
# script; we then detect the omitted-networking marker in its captured output.
dns_probe=$(builtin dnslookup localhost 2>&1) || true
case "$dns_probe" in
    *"omits libcurl"*|*"unavailable"*)
        exit 77
        ;;
esac

set -euo pipefail

dns_thread=$(builtin ThreadSpawnBuiltin str:dnslookup str:localhost)
delay_thread=$(builtin ThreadSpawnBuiltin str:delay int:10)

WaitForThread "$delay_thread"
delay_status=$EXSH_LAST_STATUS
WaitForThread "$dns_thread"
dns_status=$EXSH_LAST_STATUS

if [ "$delay_status" -ne 0 ]; then
    echo "delay_status:$delay_status" >&2
    exit 1
fi
if [ "$dns_status" -ne 0 ]; then
    echo "dns_status:$dns_status" >&2
    exit 1
fi

dns_value=$(builtin ThreadGetResult "$dns_thread")
if [ -z "${dns_value:-}" ]; then
    echo "dns_value:empty" >&2
    exit 1
fi

dns_family_valid=false
case "$dns_value" in
    *:*)
        dns_family_valid=true
        ;;
    *.*)
        dns_family_valid=true
        ;;
esac

dns_length_valid=false
if [ ${#dns_value} -gt 0 ]; then
    dns_length_valid=true
fi

dns_status_requery="consumed"

echo "delay_status:$delay_status"
echo "dns_status:$dns_status"
echo "dns_length_valid:$dns_length_valid"
echo "dns_family_valid:$dns_family_valid"
echo "dns_status_requery:$dns_status_requery"
